# Copy to .env and fill in. NEVER commit .env.

# ── LLM APIs (baseline comparison only; primary LLM is local Ollama) ──────────
OPENAI_API_KEY=sk-...

# ── Text LLM (Ollama — Report / Clinical / Supervisor agents) ────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_PRIMARY_MODEL=meditron            # Meditron-8B clinical (EPFL), installed
LLM_BASELINE_GENERAL=llama3.1:8b      # A5 ablation / general-LLM baseline, installed
LLM_STRONG_MODEL=qwen2.5:14b          # stronger reasoning fallback, installed
LLM_BASELINE_MODEL=gpt-4o             # B1 zero-shot baseline (API only)
LLM_TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT=120

# ── Vision (LLaVA-Med 7B VQA) + image embeddings (BioViL) — HF, 4-bit ────────
VLM_MODEL=microsoft/llava-med-v1.5-mistral-7b
EMBED_MODEL=microsoft/BiomedVLP-BioViL-T   # CXR image embeddings for CLIP Image RAG
LOAD_IN_4BIT=true

# ── Surrogate dataset paths (Track 1 — open datasets, not committed) ─────────
CHESTXRAY14_DIR=./data/chestxray14
OPENI_DIR=./data/openi
MIMIC_DEMO_DIR=./data/mimic_demo

# ── Neo4j (GraphRAG; optional in Track 1 — ChromaDB-only is allowed) ──────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── Vector store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma

# ── Experiment tracking ─────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns

# ── Reproducibility ──────────────────────────────────────────────────────────────
RANDOM_SEED=42
