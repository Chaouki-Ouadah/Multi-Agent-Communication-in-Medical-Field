# Copy to .env and fill in. NEVER commit .env.

# ── LLM APIs (baseline comparison only; primary LLM is local Ollama) ──────────
OPENAI_API_KEY=sk-...

# ── Local LLM serving (Ollama — primary path, free, local) ───────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_PRIMARY_MODEL=meditron            # clinical LLM (EPFL), installed locally
LLM_STRONG_MODEL=qwen2.5:14b          # stronger reasoning fallback, installed
LLM_FALLBACK_MODEL=llama3.1:8b        # general 8B fallback, installed
LLM_BASELINE_MODEL=gpt-4o             # API — comparison/baseline only
LLM_TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT=120

# ── Embeddings ──────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ── Neo4j (GraphRAG; optional in Track 1 — ChromaDB-only is allowed) ──────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── Vector store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma

# ── Experiment tracking ─────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns

# ── Reproducibility ──────────────────────────────────────────────────────────────
RANDOM_SEED=42
